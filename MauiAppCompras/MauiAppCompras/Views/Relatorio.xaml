<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppCompras.Views.Relatorio"
             Title="Relatorio">
    <VerticalStackLayout Padding="10" Spacing="10">

        <Label Text="Relatório de Compras"
               FontSize="22"
               HorizontalOptions="Center"/>

        <Label Text="Data Inicial"/>
        <DatePicker x:Name="dtInicio" Format="dd/MM/yyyy"/>

        <Label Text="Data Final"/>
        <DatePicker x:Name="dtFim" Format="dd/MM/yyyy"/>

        <Button Text="Buscar"
                Clicked="OnBuscarClicked"/>

        <CollectionView x:Name="listaProdutos">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Descricao}" />
                            <Label Text="{Binding Preco}" />
                            <Label Text="{Binding DataCompra, StringFormat='{0:dd/MM/yyyy}'}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>