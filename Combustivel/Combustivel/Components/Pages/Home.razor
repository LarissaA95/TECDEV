<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Combustivel.MainPage"
             BackgroundColor="#F7F7F7">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="25"
            VerticalOptions="Center">
            <!-- TÍTULO -->
            <Label 
                Text="Comparador de Combustível"
                FontSize="24"
                HorizontalOptions="Center"
                TextColor="#333"
                FontAttributes="Bold" />

            <!-- CAMPO ETANOL -->
            <Frame BackgroundColor="White"
                   CornerRadius="15"
                   HasShadow="True"
                   Padding="10">
                <VerticalStackLayout>
                    <Label Text="Preço do Etanol" 
                           FontSize="16"
                           TextColor="#555" />
                    <Entry x:Name="txt_etanol"
                           Placeholder="R$ 0,00"
                           Keyboard="Numeric"
                           FontSize="18"
                           TextColor="#222" />
                </VerticalStackLayout>
            </Frame>

            <!-- CAMPO GASOLINA -->
            <Frame BackgroundColor="White"
                   CornerRadius="15"
                   HasShadow="True"
                   Padding="10">
                <VerticalStackLayout>
                    <Label Text="Preço da Gasolina" 
                           FontSize="16"
                           TextColor="#555" />
                    <Entry x:Name="txt_gasolina"
                           Placeholder="R$ 0,00"
                           Keyboard="Numeric"
                           FontSize="18"
                           TextColor="#222" />
                </VerticalStackLayout>
            </Frame>

            <!-- BOTÃO -->
            <Button 
                Text="Qual compensa mais?"
                Clicked="Button_Clicked"
                BackgroundColor="#0078D7"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="20"
                HeightRequest="50"
                FontSize="18"
                HorizontalOptions="Center"
                WidthRequest="250" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
