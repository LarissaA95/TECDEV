<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMeuCombustivel.MainPage"
             Title="Qual Combustível compensa para seu veículo?">

    <ScrollView>
        <VerticalStackLayout
            Padding="20,0"
            Spacing="15"
            VerticalOptions="Center">
            <Image Source="com.jpg" 
                   HeightRequest="165" 
                   Aspect="AspectFit" 
                   HorizontalOptions="Start" />
            <Label Text="Marca do Veículo:" 
                   FontSize="18" 
                   TextColor="#333" />
            <Entry x:Name="txt_marca" 
                   Placeholder="Ex: Toyota" 
                   FontSize="18" />
            <Label Text="Modelo do Veículo:" 
                   FontSize="18" 
                   TextColor="#333" />
            <Entry x:Name="txt_modelo" 
                   Placeholder="Ex: Corolla" 
                   FontSize="18" />
            <Label Text="Preço do Etanol:" 
                   FontSize="18" 
                   TextColor="#333" />
            <Entry x:Name="txt_etanol" 
                   Placeholder="R$ " />
            <Label Text="Preço da Gasolina:" 
                   FontSize="18" TextColor="#333" />
            <Entry x:Name="txt_gasolina" 
                   Placeholder="R$ " />
            <Button x:Name="CounterBtn" 
                    Text="Qual compensa mais?" 
                    SemanticProperties.Hint="Counts the number of times you click" 
                    Clicked="OnCounterClicked" 
                    HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
